@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Booking Admin</h1>
    <p class="lead">Quản trị booking phòng tàu du lịch.</p>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Bookings</h5>
                <p class="card-text">Lịch đặt phòng theo tháng cho mỗi tàu.</p>
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary">Xem</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Lịch phòng</h5>
                <p class="card-text">xem chi tiết lịch cho từng tàu.</p>
                <a asp-controller="RoomSchedule" asp-action="Index" class="btn btn-primary">Xem</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Báo cáo</h5>
                <p class="card-text">Báo cáo doanh thu cho từng tàu.</p>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-warning">Báo cáo</a>
            </div>
        </div>
    </div>
</div>
