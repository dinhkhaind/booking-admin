@model IEnumerable<BookingAdmin.Web.Models.Boat>
@{ ViewData["Title"] = "Boats"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Boats</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Boat
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var boat in Model)
            {
                <tr>
                    <td><strong>@boat.Name</strong></td>
                    <td>@boat.Description</td>
                    <td><span class="badge @(boat.IsActive ? "bg-success" : "bg-danger")">@(boat.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@boat.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@boat.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No boats found.</div>
}
