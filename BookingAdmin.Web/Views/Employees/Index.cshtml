@model IEnumerable<BookingAdmin.Web.Models.Employee>
@{ ViewData["Title"] = "Employees"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Employees</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Employee
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model)
            {
                <tr>
                    <td><strong>@employee.FullName</strong></td>
                    <td>@employee.Phone</td>
                    <td><span class="badge @(employee.IsActive ? "bg-success" : "bg-danger")">@(employee.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No employees found.</div>
}
