@model BookingAdmin.Web.Models.Employee
@{ ViewData["Title"] = "Delete Employee"; }

<h2 class="text-danger">Delete Employee</h2>

<p class="mt-3">Are you sure you want to delete this employee?</p>

<div class="alert alert-warning mt-3">
    <strong>Name:</strong> @Model.FullName<br />
    <strong>Phone:</strong> @Model.Phone<br />
    <strong>Status:</strong> @(Model.IsActive ? "Active" : "Inactive")
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
