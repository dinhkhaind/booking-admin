@model RoomScheduleViewModel
@using System.Security.Claims;
@{
    ViewData["Title"] = "Lịch Phòng";
    var currentUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Lịch Phòng T@(Model.SelectedMonth)/@(Model.SelectedYear)</h2>
    <div class="gap-2 d-flex">
        <button class="btn btn-primary" onclick="openModal(@Model.SelectedBoatId, null)">
            <i class="bi bi-plus"></i> Booking Mới
        </button>
        <button class="btn btn-secondary" onclick="blockRoom()">
            <i class="bi bi-lock"></i> Block Phòng
        </button>
    </div>
</div>

<!-- Current User Data (for modal) -->
<div class="d-none" data-current-user="@currentUser" data-current-user-id="@currentUserId"></div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Tàu</label>
                <select name="boatId" class="form-select" onchange="this.form.submit()">
                    @foreach (var boat in Model.Boats)
                    {
                        <option value="@boat.Id" selected="@(boat.Id == Model.SelectedBoatId)">@boat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tháng</label>
                <select name="month" class="form-select" onchange="this.form.submit()">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.SelectedMonth)">Tháng @m</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Năm</label>
                <select name="year" class="form-select" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 2; y++)
                    {
                        <option value="@y" selected="@(y == Model.SelectedYear)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại Phòng</label>
                <select name="roomTypeId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Tất Cả --</option>
                    @foreach (var rt in Model.RoomTypes)
                    {
                        <option value="@rt.Id" selected="@(rt.Id == Model.SelectedRoomTypeId)">@rt.Name</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<!-- Metrics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="text-muted">Công Suất</h5>
                <h3 class="text-primary">@Model.OccupancyRate.ToString("F1")%</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="text-muted">Doanh Thu</h5>
                <p class="text-success" style="font-size: 0.95rem; line-height: 1.4; margin: 0;">
                    @if (!string.IsNullOrEmpty(Model.RevenueByCurrency))
                    {
                        @Html.Raw(Model.RevenueByCurrency)
                    }
                    else
                    {
                        <span>0</span>
                    }
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="text-muted">Hiệu Lực</h5>
                <h3 class="text-info">@Model.ActiveBookingCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="text-muted">Last-Min</h5>
                <h3 class="text-warning">@Model.LastMinuteBookingCount</h3>
            </div>
        </div>
    </div>
</div>

<!-- Grid -->
<div class="card">
    <div class="card-body" style="overflow-x: auto; overflow-y: auto; max-height: 600px;">
        <table class="table table-bordered mb-0 room-schedule-table">
            <thead class="sticky-top">
                <tr>
                    <th style="position: sticky; left: 0; z-index: 11; background: white; min-width: 150px;">Phòng</th>
                    @for (int day = 1; day <= Model.DaysInMonth; day++)
                    {
                        var date = new DateTime(Model.SelectedYear, Model.SelectedMonth, day);
                        var dayOfWeek = date.DayOfWeek;
                        var isWeekend = dayOfWeek == DayOfWeek.Saturday || dayOfWeek == DayOfWeek.Sunday;
                        var dayNames = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
                        var bgStyle = isWeekend ? "background-color: rgb(41 102 236 / 34%); color: #d12525;" : "";

                        <th class="text-center day-header" style="min-width: 60px; @bgStyle">
                            <div>@day</div>
                            <small class="text-muted">@dayNames[(int)dayOfWeek]</small>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td style="position: sticky; left: 0; background: white; z-index: 10; min-width: 150px;">
                            <strong>@row.RoomCode</strong><br/>
                            <small class="text-muted">@row.RoomTypeName</small>
                        </td>
                        @foreach (var cell in row.Days)
                        {
                            var cellDate = new DateTime(Model.SelectedYear, Model.SelectedMonth, cell.Day);
                            var cellDayOfWeek = cellDate.DayOfWeek;
                            var isWeekend = cellDayOfWeek == DayOfWeek.Saturday || cellDayOfWeek == DayOfWeek.Sunday;
                            var weekendBg = isWeekend ? "background-color: rgba(37, 99, 235, 0.06);" : "";

                            @if (cell.IsEmpty)
                            {
                                <td class="sched-empty" data-room-id="@row.RoomId" data-day="@cell.Day"
                                    style="cursor: pointer; @weekendBg"
                                    onclick="openBookingModal(@row.RoomId, @cell.Day)"></td>
                            }
                            else if (cell.Block != null && cell.IsStart)
                            {
                                <td colspan="@cell.ColSpan" class="sched-block" data-block-id="@cell.Block.BlockId"
                                    onclick="openBlockDetailModal(@cell.Block.BlockId)">
                                    <strong><i class="bi bi-lock"></i> @cell.Block.Partner</strong><br/>
                                    @if (!string.IsNullOrEmpty(cell.Block.Note))
                                    {
                                        <small>@cell.Block.Note</small>
                                    }
                                </td>
                            }
                            else if (cell.Booking != null && cell.IsStart)
                            {
                                var chipColor = cell.Booking.PackageAddedDate == 1 ? "#d97706" : "#2563eb";
                                <td colspan="@cell.ColSpan" class="sched-booking" data-booking-id="@cell.Booking.BookingId"
                                    style="background-color: @chipColor; cursor: pointer; color: white; font-size: 0.85rem; padding: 4px;"
                                    onclick="openDetailModal(@cell.Booking.BookingId)">
                                    <strong>@cell.Booking.ChannelName</strong><br/>
                                    <small>@cell.Booking.PackageCode</small>
                                </td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Booking Modal -->
@await Html.PartialAsync("_BookingModal", Model)

<!-- Block Room Modal -->
@await Html.PartialAsync("_RoomBlockModal", Model)

<!-- Shared Detail Drawer -->
@await Html.PartialAsync("_BookingDetailDrawer")

<style>
    .room-schedule-table {
        border-collapse: collapse;
    }

    .sched-empty {
        height: 60px;
        border: 1px solid #ddd;
    }

    .sched-booking {
        border: 1px solid #ddd;
        text-align: center;
        min-height: 60px;
        vertical-align: middle;
        opacity: 0.9;
        font-size: 0.70;
    }

    .sched-booking:hover {
        opacity: 1;
    }

    .sched-block {
        border: 1px solid #ddd;
        text-align: center;
        min-height: 60px;
        vertical-align: middle;
        background-color: #dc3545 !important;
        color: white !important;
        font-size: 0.70rem;
        padding: 4px;
        cursor: pointer;
        opacity: 0.9;
    }

    .sched-block:hover {
        opacity: 1;
    }
</style>

<script>
    function openBookingModal(roomId, day) {
        const checkIn = new Date(@Model.SelectedYear, @Model.SelectedMonth - 1, day);
        const checkInStr = checkIn.toISOString().split('T')[0];
        openModal(@Model.SelectedBoatId, checkInStr);
    }

    function blockRoom() {
        openBlockModal(@Model.SelectedBoatId, null);
    }

    async function openBlockDetailModal(blockId) {
        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`);

            // Read as text first
            const responseText = await response.text();
            if (!responseText) {
                alert('Lỗi: Server không trả về dữ liệu');
                return;
            }

            let block;
            try {
                block = JSON.parse(responseText);
            } catch (e) {
                console.error('JSON parse error:', e);
                alert('Lỗi: Dữ liệu từ server không hợp lệ');
                return;
            }

            if (!block.success && block.error) {
                alert('Lỗi: ' + block.error);
                return;
            }
            let html = `
                <div class="booking-detail-panel">
                    <div class="detail-group">
                        <h6 class="group-title">Thông Tin Block</h6>
                        <div class="detail-row">
                            <div class="detail-label">Phòng:</div>
                            <div class="detail-value">${block.roomCode} - ${block.roomName}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Từ Ngày:</div>
                            <div class="detail-value">${block.fromDate}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Đến Ngày:</div>
                            <div class="detail-value">${block.toDate}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Đối Tác:</div>
                            <div class="detail-value">${block.partner || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Hạn Chốt:</div>
                            <div class="detail-value">${block.deadline || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Ghi Chú:</div>
                            <div class="detail-value">${block.note || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Tạo Bởi:</div>
                            <div class="detail-value">${block.createdBy || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Ngày Tạo:</div>
                            <div class="detail-value">${block.createdAt}</div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('detailContent').innerHTML = html;

            // Update footer with delete button
            const footer = document.querySelector('.drawer-footer');
            footer.innerHTML = `
                <button type="button" class="btn btn-danger" onclick="deleteBlock(${blockId})">
                    <i class="bi bi-trash"></i> Xoá Block
                </button>
            `;

            openDetailDrawer();
        } catch (error) {
            console.error('Error loading block:', error);
            alert('Lỗi tải thông tin block');
        }
    }

    async function deleteBlock(blockId) {
        if (!confirm('Bạn chắc chắn muốn xoá block này?')) return;

        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`, {
                method: 'DELETE'
            });

            // Read as text first
            const responseText = await response.text();
            let data = {};

            if (responseText) {
                try {
                    data = JSON.parse(responseText);
                } catch (e) {
                    console.error('JSON parse error:', e);
                    alert('Lỗi: Server trả về dữ liệu không hợp lệ');
                    return;
                }
            }

            if (data.success === false || (response.status >= 400 && !data.success)) {
                alert('Lỗi: ' + (data.error || 'Không thể xoá block'));
                return;
            }

            if (data.success === true) {
                alert('Xoá block thành công!');
                closeDetailDrawer();
                location.reload();
            }
        } catch (error) {
            console.error('Error deleting block:', error);
            alert('Lỗi: ' + error.message);
        }
    }
</script>

@section Scripts {
    <script src="~/js/booking-shared.js" asp-append-version="true"></script>
}
