@model RoomScheduleViewModel
@using System.Security.Claims;
@{
    ViewData["Title"] = "Lịch Phòng";
    var currentUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Lịch Phòng T@(Model.SelectedMonth)/@(Model.SelectedYear)</h2>
    <div class="gap-2 d-flex">
        <button class="btn btn-primary" onclick="openModal(@Model.SelectedBoatId, null)">
            <i class="bi bi-plus"></i> Booking Mới
        </button>
        <button class="btn btn-secondary" onclick="blockRoom()">
            <i class="bi bi-lock"></i> Block Phòng
        </button>
    </div>
</div>

<!-- Current User Data (for modal) -->
<div class="d-none" data-current-user="@currentUser" data-current-user-id="@currentUserId" data-boat-events="@Model.BoatEventsJson"></div>

<script>
    // Parse boat events for calendar
    let boatEventsMap = {};
    const boatEventsJson = document.querySelector('[data-boat-events]').getAttribute('data-boat-events');
    if (boatEventsJson) {
        try {
            const boatEvents = JSON.parse(boatEventsJson);
            boatEvents.forEach(event => {
                const fromDate = new Date(event.fromDate);
                const toDate = new Date(event.toDate);
                for (let d = new Date(fromDate); d <= toDate; d.setDate(d.getDate() + 1)) {
                    const dateStr = d.toISOString().split('T')[0];
                    if (!boatEventsMap[dateStr]) {
                        boatEventsMap[dateStr] = [];
                    }
                    boatEventsMap[dateStr].push({
                        type: event.type,
                        reason: event.reason
                    });
                }
            });
        } catch (e) {
            console.error('Error parsing boat events:', e);
        }
    }

    const selectedYear = @Model.SelectedYear;
    const selectedMonth = @Model.SelectedMonth;
    const daysInMonth = @Model.DaysInMonth;

    function getEventForDate(day) {
        const yearStr = selectedYear.toString().padStart(4, '0');
        const monthStr = selectedMonth.toString().padStart(2, '0');
        const dayStr = day.toString().padStart(2, '0');
        const dateStr = `${yearStr}-${monthStr}-${dayStr}`;
        return boatEventsMap[dateStr] || null;
    }

    function handleDateCellClick(e, roomId, day) {
        const boatEvent = getEventForDate(day);
        const hasDowntime = boatEvent?.some(evt => evt.type === 'Downtime') ?? false;

        if (hasDowntime) {
            e.preventDefault();
            e.stopPropagation();
            alert('Tàu dừng hoạt động vào ngày này. Vui lòng chọn ngày khác.');
            return false;
        }

        openBookingModal(roomId, day);
        return false;
    }

    // Apply event colors to day headers and cells on page load
    document.addEventListener('DOMContentLoaded', function() {
        for (let day = 1; day <= daysInMonth; day++) {
            const dayEvent = getEventForDate(day);
            if (dayEvent) {
                const headerEl = document.getElementById(`day-header-${day}`);
                if (headerEl) {
                    if (dayEvent.some(e => e.type === 'Downtime')) {
                        headerEl.style.backgroundColor = '#e8e8e8';
                        headerEl.style.cursor = 'not-allowed';
                    } else if (dayEvent.some(e => e.type === 'Surcharge')) {
                        headerEl.style.backgroundColor = '#d4edda';
                        headerEl.style.cursor = 'help';
                        const reason = dayEvent.find(e => e.type === 'Surcharge')?.reason;
                        if (reason) {
                            headerEl.title = 'Phụ thu: ' + reason;
                        }
                    }
                }
            }
        }

        // Apply event colors to empty cells
        document.querySelectorAll('.sched-empty').forEach(cell => {
            const day = parseInt(cell.getAttribute('data-day'));
            const dayEvent = getEventForDate(day);
            if (dayEvent) {
                if (dayEvent.some(e => e.type === 'Downtime')) {
                    cell.style.backgroundColor = '#e8e8e8';
                    cell.style.cursor = 'not-allowed';
                    cell.style.pointerEvents = 'none';
                    const addBtn = cell.querySelector('.cell-add-btn');
                    if (addBtn) addBtn.style.display = 'none';
                } else if (dayEvent.some(e => e.type === 'Surcharge')) {
                    cell.style.backgroundColor = '#d4edda';
                    cell.style.cursor = 'help';
                    const reason = dayEvent.find(e => e.type === 'Surcharge')?.reason;
                    if (reason) {
                        cell.title = 'Phụ thu: ' + reason;
                    }
                }
            }
        });
    });
</script>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Tàu</label>
                <select name="boatId" class="form-select" onchange="this.form.submit()">
                    @foreach (var boat in Model.Boats)
                    {
                        <option value="@boat.Id" selected="@(boat.Id == Model.SelectedBoatId)">@boat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tháng</label>
                <select name="month" class="form-select" onchange="this.form.submit()">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.SelectedMonth)">Tháng @m</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Năm</label>
                <select name="year" class="form-select" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 2; y++)
                    {
                        <option value="@y" selected="@(y == Model.SelectedYear)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại Phòng</label>
                <select name="roomTypeId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Tất Cả --</option>
                    @foreach (var rt in Model.RoomTypes)
                    {
                        <option value="@rt.Id" selected="@(rt.Id == Model.SelectedRoomTypeId)">@rt.Name</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<!-- Metrics -->
<div class="row mb-3 g-2">
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Công Suất</div>
                <div class="metric-value text-primary">@Model.OccupancyRate.ToString("F1")%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Doanh Thu</div>
                <div class="metric-value text-success">
                    @if (!string.IsNullOrEmpty(Model.RevenueByCurrency))
                    {
                        @Html.Raw(Model.RevenueByCurrency)
                    }
                    else
                    {
                        <span>0</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Hiệu Lực</div>
                <div class="metric-value text-info">@Model.ActiveBookingCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Last-Min</div>
                <div class="metric-value text-warning">@Model.LastMinuteBookingCount</div>
            </div>
        </div>
    </div>
</div>

<!-- Grid - 1 scroll container duy nhất -->
<div class="card p-0">
    <div class="schedule-container" id="scheduleContainer">
        <div class="schedule-grid" id="scheduleGrid">

            <!-- Header corner (sticky top+left) -->
            <div class="sched-corner">Phòng</div>

            <!-- Header ngày (sticky top) -->
            @for (int day = 1; day <= Model.DaysInMonth; day++)
            {
                var date = new DateTime(Model.SelectedYear, Model.SelectedMonth, day);
                var dow = date.DayOfWeek;
                var isWeekend = dow == DayOfWeek.Saturday || dow == DayOfWeek.Sunday;
                var dayNames = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
                <div class="sched-day-header @(isWeekend ? "is-weekend" : "")" id="day-header-@day" data-day="@day">
                    <div class="day-num">@day</div>
                    <div class="day-name">@dayNames[(int)dow]</div>
                </div>
            }

            <!-- Room rows -->
            @foreach (var row in Model.Rows)
            {
                <!-- Cột phòng (sticky left) -->
                <div class="sched-room-info" style="@(!string.IsNullOrEmpty(row.RoomTypeColor) ? $"background: {row.RoomTypeColor}80;" : "")">
                    <div class="ri-line1">
                        <span class="ri-code">@row.RoomCode</span>
                        <span class="ri-sep"> – </span>
                        <span class="ri-type">@row.RoomTypeName</span>
                    </div>
                    <div class="ri-line2">@row.RoomName</div>
                    <div class="ri-line3">@row.Location</div>
                </div>

                <!-- Các ô ngày -->
                @foreach (var cell in row.Days)
                {
                    var cellDate = new DateTime(Model.SelectedYear, Model.SelectedMonth, cell.Day);
                    var isWeekend = cellDate.DayOfWeek == DayOfWeek.Saturday || cellDate.DayOfWeek == DayOfWeek.Sunday;

                    if (cell.IsEmpty)
                    {
                        <div class="sched-cell sched-empty @(isWeekend ? "is-weekend-col" : "")"
                             style="grid-column: span @cell.ColSpan"
                             onclick="return handleDateCellClick(event, @row.RoomId, @cell.Day)"
                             data-day="@cell.Day"
                             data-room-id="@row.RoomId">
                        <span class="cell-add-btn">+</span>
                        </div>
                    }
                    else if (cell.Block != null && cell.IsStart)
                    {
                        <div class="sched-cell sched-block"
                             style="grid-column: span @cell.ColSpan"
                             onclick="openBlockDetailModal(@cell.Block.BlockId)">
                            <i class="bi bi-lock"></i> @cell.Block.Partner
                        </div>
                    }
                    else if (cell.Booking != null && cell.IsStart)
                    {
                        var chipColor = cell.Booking.PackageAddedDate == 1 ? "#d97706" : "#2563eb";
                        var backgroundStyle = cell.Booking.IsTransferred
                            ? $"background: linear-gradient(to right, {chipColor} 0%, {chipColor} 70%, #9333ea 70%, #9333ea 100%)"
                            : $"background: {chipColor}";
                        <div class="sched-cell sched-booking"
                             style="@backgroundStyle; grid-column: span @cell.ColSpan"
                             onclick="openDetailModal(@cell.Booking.BookingId)">
                            <div class="chip-l1">@cell.Booking.ChannelName</div>
                            <div class="chip-l2">@cell.Booking.PackageCode</div>
                        </div>
                    }
                }
            }

        </div>
    </div>
</div>

<!-- Booking Modal -->
@await Html.PartialAsync("_BookingModal", Model)

<!-- Block Room Modal -->
@await Html.PartialAsync("_RoomBlockModal", Model)

<!-- Shared Detail Drawer -->
@await Html.PartialAsync("_BookingDetailDrawer")

<!-- Transfer Boat Modal -->
@await Html.PartialAsync("_TransferBoatModal", Model)

<style>
    /* ── Metric Cards ── */
    .metric-card .card-body {
        padding: 0.5rem 0.75rem !important;
        text-align: center;
    }
    .metric-label {
        font-size: 0.7rem;
        color: #6c757d;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .metric-value {
        font-size: 0.85rem;
        font-weight: 600;
        margin: 0;
    }

    /* ── Schedule: 1 scroll container duy nhất ── */
    .schedule-container {
        overflow: auto;
        max-height: calc(100vh - 280px);
        border: 1px solid #dee2e6;
        border-radius: 4px;
        background: white;
    }

    .schedule-grid {
        display: grid;
        /* cột đầu cố định 150px, các cột ngày 55px mỗi cái */
        grid-template-columns: 150px repeat(var(--day-count, 31), 80px);
        min-width: max-content;
    }

    /* ── Header corner: sticky top + left ── */
    .sched-corner {
        position: sticky;
        top: 0;
        left: 0;
        z-index: 20;
        background: #f8f9fa;
        border-right: 2px solid #ced4da;
        border-bottom: 2px solid #ced4da;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        height: 55px;
    }

    /* ── Header ngày: sticky top ── */
    .sched-day-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: white;
        border: 1px solid #e9ecef;
        border-bottom: 2px solid #ced4da;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 55px;
    }
    .sched-day-header.is-weekend {
        background: rgba(37, 99, 235, 0.08);
    }
    .day-num {
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1;
    }
    .day-name {
        font-size: 0.7rem;
        color: #6c757d;
        margin-top: 2px;
    }
    .sched-day-header.is-weekend .day-num,
    .sched-day-header.is-weekend .day-name {
        color: #dc2626;
    }

    /* ── Cột phòng: sticky left ── */
    .sched-room-info {
        position: sticky;
        left: 0;
        z-index: 5;
        background: white;
        border-right: 2px solid #ced4da;
        border-bottom: 1px solid #e9ecef;
        padding: 6px 8px;
        min-height: 65px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 2px;
    }
    .ri-line1 {
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ri-code { font-weight: 700; }
    .ri-sep  { color: #adb5bd; }
    .ri-type { font-weight: 400; color: #032950; }
    .ri-line2, .ri-line3 {
        font-size: 0.6rem;
        color: #032950;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
    }

    /* ── Cells ── */
    .sched-cell {
        border: 1px solid #e9ecef;
        min-height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3px 4px;
    }

    .sched-empty {
        cursor: pointer;
        background: white;
    }
    .sched-empty:hover { background: #f0f4ff; }
    .sched-empty.is-weekend-col { background: rgba(37, 99, 235, 0.04); }
    .sched-empty.is-weekend-col:hover { background: #e8effe; }

    .sched-booking {
        color: white;
        cursor: pointer;
        padding: 4px 5px;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        gap: 2px;
        opacity: 0.92;
    }
    .sched-booking:hover { opacity: 1; }
    .chip-l1 {
        font-weight: 600;
        font-size: 0.75rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        width: 100%;
    }
    .chip-l2 {
        font-size: 0.68rem;
        opacity: 0.85;
    }

    .sched-block {
        background: #dc3545 !important;
        color: white !important;
        font-size: 0.7rem;
        cursor: pointer;
        opacity: 0.9;
        text-align: center;
    }
    .sched-block:hover { opacity: 1; }
    .cell-add-btn {
        display: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #2563eb;
        color: white;
        font-size: 1rem;
        line-height: 22px;
        text-align: center;
        cursor: pointer;
        user-select: none;
    }
    .sched-empty:hover .cell-add-btn {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Tooltip styling ── */
    [title] {
        position: relative;
    }
    .sched-empty[title]:hover,
    .sched-day-header[title]:hover {
        border: 1px dotted #666;
    }
</style>

<script>
    function openBookingModal(roomId, day) {
        const checkIn = new Date(@Model.SelectedYear, @Model.SelectedMonth - 1, day);
        const checkInStr = checkIn.toISOString().split('T')[0];
        openModal(@Model.SelectedBoatId, checkInStr);
    }

    function blockRoom() {
        openBlockModal(@Model.SelectedBoatId, null);
    }

    async function openBlockDetailModal(blockId) {
        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`);
            const responseText = await response.text();
            if (!responseText) { alert('Lỗi: Server không trả về dữ liệu'); return; }

            let block;
            try { block = JSON.parse(responseText); }
            catch (e) { alert('Lỗi: Dữ liệu từ server không hợp lệ'); return; }

            if (!block.success && block.error) { alert('Lỗi: ' + block.error); return; }

            document.getElementById('detailContent').innerHTML = `
                <div class="booking-detail-panel">
                    <div class="detail-group">
                        <h6 class="group-title">Thông Tin Block</h6>
                        <div class="detail-row"><div class="detail-label">Phòng:</div><div class="detail-value">${block.roomCode} - ${block.roomName}</div></div>
                        <div class="detail-row"><div class="detail-label">Từ Ngày:</div><div class="detail-value">${block.fromDate}</div></div>
                        <div class="detail-row"><div class="detail-label">Đến Ngày:</div><div class="detail-value">${block.toDate}</div></div>
                        <div class="detail-row"><div class="detail-label">Đối Tác:</div><div class="detail-value">${block.partner || '-'}</div></div>
                        <div class="detail-row"><div class="detail-label">Hạn Chốt:</div><div class="detail-value">${block.deadline || '-'}</div></div>
                        <div class="detail-row"><div class="detail-label">Ghi Chú:</div><div class="detail-value">${block.note || '-'}</div></div>
                        <div class="detail-row"><div class="detail-label">Tạo Bởi:</div><div class="detail-value">${block.createdBy || '-'}</div></div>
                        <div class="detail-row"><div class="detail-label">Ngày Tạo:</div><div class="detail-value">${block.createdAt}</div></div>
                    </div>
                </div>`;

            document.querySelector('.drawer-footer').innerHTML = `
                <button type="button" class="btn btn-danger" onclick="deleteBlock(${blockId})">
                    <i class="bi bi-trash"></i> Xoá Block
                </button>`;

            openDetailDrawer();
        } catch (error) {
            alert('Lỗi tải thông tin block');
        }
    }

    async function deleteBlock(blockId) {
        if (!confirm('Bạn chắc chắn muốn xoá block này?')) return;
        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`, { method: 'DELETE' });
            const responseText = await response.text();
            let data = {};
            if (responseText) {
                try { data = JSON.parse(responseText); }
                catch (e) { alert('Lỗi: Server trả về dữ liệu không hợp lệ'); return; }
            }
            if (data.success === false) { alert('Lỗi: ' + (data.error || 'Không thể xoá block')); return; }
            if (data.success === true) { alert('Xoá block thành công!'); closeDetailDrawer(); location.reload(); }
        } catch (error) {
            alert('Lỗi: ' + error.message);
        }
    }
</script>

@section Scripts {
    <script src="~/js/booking-shared.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dayCount = @Model.DaysInMonth;
            const grid = document.getElementById('scheduleGrid');
            if (grid) {
                grid.style.setProperty('--day-count', dayCount);
                grid.style.gridTemplateColumns = `150px repeat(${dayCount}, 80px)`;
            }
        });
    </script>
}
