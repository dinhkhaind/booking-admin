@model RoomScheduleViewModel
@using System.Security.Claims;
@{
    ViewData["Title"] = "Lịch Phòng";
    var currentUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Lịch Phòng T@(Model.SelectedMonth)/@(Model.SelectedYear)</h2>
    <div class="gap-2 d-flex">
        <button class="btn btn-primary" onclick="openModal(@Model.SelectedBoatId, null)">
            <i class="bi bi-plus"></i> Booking Mới
        </button>
        <button class="btn btn-secondary" onclick="blockRoom()">
            <i class="bi bi-lock"></i> Block Phòng
        </button>
    </div>
</div>

<!-- Current User Data (for modal) -->
<div class="d-none" data-current-user="@currentUser" data-current-user-id="@currentUserId"></div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Tàu</label>
                <select name="boatId" class="form-select" onchange="this.form.submit()">
                    @foreach (var boat in Model.Boats)
                    {
                        <option value="@boat.Id" selected="@(boat.Id == Model.SelectedBoatId)">@boat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tháng</label>
                <select name="month" class="form-select" onchange="this.form.submit()">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.SelectedMonth)">Tháng @m</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Năm</label>
                <select name="year" class="form-select" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 2; y++)
                    {
                        <option value="@y" selected="@(y == Model.SelectedYear)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại Phòng</label>
                <select name="roomTypeId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Tất Cả --</option>
                    @foreach (var rt in Model.RoomTypes)
                    {
                        <option value="@rt.Id" selected="@(rt.Id == Model.SelectedRoomTypeId)">@rt.Name</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<!-- Metrics -->
<div class="row mb-3 g-2">
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Công Suất</div>
                <div class="metric-value text-primary">@Model.OccupancyRate.ToString("F1")%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Doanh Thu</div>
                <div class="metric-value text-success">
                    @if (!string.IsNullOrEmpty(Model.RevenueByCurrency))
                    {
                        @Html.Raw(Model.RevenueByCurrency)
                    }
                    else
                    {
                        <span>0</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Hiệu Lực</div>
                <div class="metric-value text-info">@Model.ActiveBookingCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Last-Min</div>
                <div class="metric-value text-warning">@Model.LastMinuteBookingCount</div>
            </div>
        </div>
    </div>
</div>

<!-- Grid with Fixed Left Column -->
<div class="card">
    <div class="schedule-container">
        <!-- Fixed Left Column (Room Names) -->
        <div class="schedule-left-fixed">
            <!-- Header -->
            <div class="schedule-header-left">Phòng</div>
            <!-- Room Rows -->
            @foreach (var row in Model.Rows)
            {
                <div class="schedule-room-cell">
                    <!-- Line 1: RoomCode - Location -->
                    <div class="room-cell-line1">
                        <span class="room-cell-code">@row.RoomCode</span>
                        @if (!string.IsNullOrEmpty(row.Location))
                        {
                            <span> – </span>
                            <span class="room-cell-location">@row.Location</span>
                        }
                    </div>
                    <!-- Line 2: RoomName -->
                    <div class="room-cell-name">@row.RoomName</div>
                </div>
            }
        </div>

        <!-- Scrollable Content -->
        <div class="schedule-scroll-wrapper">
            <div class="schedule-grid">
                <!-- Header Row (Dates) -->
                <div class="schedule-header-row">
                    @for (int day = 1; day <= Model.DaysInMonth; day++)
                    {
                        var date = new DateTime(Model.SelectedYear, Model.SelectedMonth, day);
                        var dayOfWeek = date.DayOfWeek;
                        var isWeekend = dayOfWeek == DayOfWeek.Saturday || dayOfWeek == DayOfWeek.Sunday;
                        var dayNames = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
                        var bgStyle = isWeekend ? "background-color: rgb(41 102 236 / 34%); color: #d12525;" : "";

                        <div class="schedule-day-header text-center" style="@bgStyle">
                            <div>@day</div>
                            <small class="text-muted">@dayNames[(int)dayOfWeek]</small>
                        </div>
                    }
                </div>

                <!-- Content Rows -->
                @foreach (var row in Model.Rows)
                {
                    <div class="schedule-content-row">
                        @foreach (var cell in row.Days)
                        {
                            var cellDate = new DateTime(Model.SelectedYear, Model.SelectedMonth, cell.Day);
                            var cellDayOfWeek = cellDate.DayOfWeek;
                            var isWeekend = cellDayOfWeek == DayOfWeek.Saturday || cellDayOfWeek == DayOfWeek.Sunday;
                            var weekendBg = isWeekend ? "background-color: rgba(37, 99, 235, 0.06);" : "";

                            @if (cell.IsEmpty)
                            {
                                <div class="schedule-cell sched-empty" data-room-id="@row.RoomId" data-day="@cell.Day"
                                    style="cursor: pointer; grid-column: span @cell.ColSpan; @weekendBg"
                                    onclick="openBookingModal(@row.RoomId, @cell.Day)"></div>
                            }
                            else if (cell.Block != null && cell.IsStart)
                            {
                                <div class="schedule-cell sched-block" data-block-id="@cell.Block.BlockId"
                                    style="grid-column: span @cell.ColSpan;"
                                    onclick="openBlockDetailModal(@cell.Block.BlockId)">
                                    <strong><i class="bi bi-lock"></i> @cell.Block.Partner</strong><br/>
                                    @if (!string.IsNullOrEmpty(cell.Block.Note))
                                    {
                                        <small>@cell.Block.Note</small>
                                    }
                                </div>
                            }
                            else if (cell.Booking != null && cell.IsStart)
                            {
                                var chipColor = cell.Booking.PackageAddedDate == 1 ? "#d97706" : "#2563eb";
                                <div class="schedule-cell sched-booking" data-booking-id="@cell.Booking.BookingId"
                                    style="background-color: @chipColor; grid-column: span @cell.ColSpan;"
                                    onclick="openDetailModal(@cell.Booking.BookingId)">
                                    <div class="booking-chip-line1">@cell.Booking.ChannelName</div>
                                    <div class="booking-chip-line2">@cell.Booking.PackageCode</div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Booking Modal -->
@await Html.PartialAsync("_BookingModal", Model)

<!-- Block Room Modal -->
@await Html.PartialAsync("_RoomBlockModal", Model)

<!-- Shared Detail Drawer -->
@await Html.PartialAsync("_BookingDetailDrawer")

<style>
    /* Metric Cards */
    .metric-card .card-body {
        padding: 0.5rem 0.75rem !important;
        text-align: center;
    }

    .metric-label {
        font-size: 0.7rem;
        color: #6c757d;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .metric-value {
        font-size: 0.85rem;
        font-weight: 600;
        margin: 0;
    }

    .schedule-container {
        display: flex;
        max-height: 600px;
        border: 1px solid #dee2e6;
        background: white;
    }

    /* Fixed Left Column */
    .schedule-left-fixed {
        width: 150px;
        flex-shrink: 0;
        border-right: 2px solid #dee2e6;
        overflow-y: auto;
        background: white;
        z-index: 100;
    }

    .schedule-header-left {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 60px;
        font-weight: bold;
        font-size: 0.9rem;
        border-bottom: 1px solid #dee2e6;
        background: white;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .schedule-room-cell {
        padding: 6px 8px;
        border-bottom: 1px solid #ddd;
        min-height: 70px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 3px;
        background: white;
    }

    .room-cell-line1 {
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1.2;
    }

    .room-cell-code {
        font-weight: 700;
    }

    .room-cell-location {
        font-size: 0.6rem;
        color: #6c757d;
        font-weight: normal;
    }

    .room-cell-name {
        font-size: 0.6rem;
        color: #6c757d;
        line-height: 1.3;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Scrollable Area */
    .schedule-scroll-wrapper {
        flex: 1;
        overflow-x: auto;
        overflow-y: auto;
        position: relative;
    }

    /* Grid Container */
    .schedule-grid {
        display: grid;
        grid-template-columns: repeat(var(--day-count), 60px);
        min-width: min-content;
        width: 100%;
    }

    /* Header Row (Dates) */
    .schedule-header-row {
        display: contents;
    }

    .schedule-day-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 60px;
        border: 1px solid #ddd;
        border-bottom: 2px solid #dee2e6;
        font-weight: 500;
        font-size: 0.85rem;
        background: white;
        position: sticky;
        top: 0;
        z-index: 11;
    }

    /* Content Rows */
    .schedule-content-row {
        display: contents;
    }

    .schedule-cell {
        border: 1px solid #ddd;
        min-height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4px;
    }

    .sched-empty {
        background: white;
        cursor: pointer;
    }

    .sched-empty:hover {
        background-color: #f8f9fa;
    }

    .sched-booking {
        border: 1px solid #ddd;
        color: white;
        padding: 3px 4px;
        cursor: pointer;
        opacity: 0.9;
        display: flex !important;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
    }

    .booking-chip-line1 {
        font-weight: 600;
        font-size: 0.75rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        width: 100%;
    }

    .booking-chip-line2 {
        font-size: 0.7rem;
        opacity: 0.85;
    }

    .sched-booking:hover {
        opacity: 1;
    }

    .sched-block {
        border: 1px solid #dc3545;
        text-align: center;
        background-color: #dc3545 !important;
        color: white !important;
        font-size: 0.70rem;
        padding: 4px;
        cursor: pointer;
        opacity: 0.9;
    }

    .sched-block:hover {
        opacity: 1;
    }

    /* Synchronize scrolling */
    .schedule-scroll-wrapper {
        scroll-behavior: smooth;
    }
</style>

<script>
    function openBookingModal(roomId, day) {
        const checkIn = new Date(@Model.SelectedYear, @Model.SelectedMonth - 1, day);
        const checkInStr = checkIn.toISOString().split('T')[0];
        openModal(@Model.SelectedBoatId, checkInStr);
    }

    function blockRoom() {
        openBlockModal(@Model.SelectedBoatId, null);
    }

    async function openBlockDetailModal(blockId) {
        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`);

            // Read as text first
            const responseText = await response.text();
            if (!responseText) {
                alert('Lỗi: Server không trả về dữ liệu');
                return;
            }

            let block;
            try {
                block = JSON.parse(responseText);
            } catch (e) {
                console.error('JSON parse error:', e);
                alert('Lỗi: Dữ liệu từ server không hợp lệ');
                return;
            }

            if (!block.success && block.error) {
                alert('Lỗi: ' + block.error);
                return;
            }
            let html = `
                <div class="booking-detail-panel">
                    <div class="detail-group">
                        <h6 class="group-title">Thông Tin Block</h6>
                        <div class="detail-row">
                            <div class="detail-label">Phòng:</div>
                            <div class="detail-value">${block.roomCode} - ${block.roomName}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Từ Ngày:</div>
                            <div class="detail-value">${block.fromDate}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Đến Ngày:</div>
                            <div class="detail-value">${block.toDate}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Đối Tác:</div>
                            <div class="detail-value">${block.partner || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Hạn Chốt:</div>
                            <div class="detail-value">${block.deadline || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Ghi Chú:</div>
                            <div class="detail-value">${block.note || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Tạo Bởi:</div>
                            <div class="detail-value">${block.createdBy || '-'}</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Ngày Tạo:</div>
                            <div class="detail-value">${block.createdAt}</div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('detailContent').innerHTML = html;

            // Update footer with delete button
            const footer = document.querySelector('.drawer-footer');
            footer.innerHTML = `
                <button type="button" class="btn btn-danger" onclick="deleteBlock(${blockId})">
                    <i class="bi bi-trash"></i> Xoá Block
                </button>
            `;

            openDetailDrawer();
        } catch (error) {
            console.error('Error loading block:', error);
            alert('Lỗi tải thông tin block');
        }
    }

    async function deleteBlock(blockId) {
        if (!confirm('Bạn chắc chắn muốn xoá block này?')) return;

        try {
            const response = await fetch(`/lich-phong/api/room-blocks/${blockId}`, {
                method: 'DELETE'
            });

            // Read as text first
            const responseText = await response.text();
            let data = {};

            if (responseText) {
                try {
                    data = JSON.parse(responseText);
                } catch (e) {
                    console.error('JSON parse error:', e);
                    alert('Lỗi: Server trả về dữ liệu không hợp lệ');
                    return;
                }
            }

            if (data.success === false || (response.status >= 400 && !data.success)) {
                alert('Lỗi: ' + (data.error || 'Không thể xoá block'));
                return;
            }

            if (data.success === true) {
                alert('Xoá block thành công!');
                closeDetailDrawer();
                location.reload();
            }
        } catch (error) {
            console.error('Error deleting block:', error);
            alert('Lỗi: ' + error.message);
        }
    }
</script>

@section Scripts {
    <script src="~/js/booking-shared.js" asp-append-version="true"></script>
    <script>
        // Set grid column count for responsive layout
        document.addEventListener('DOMContentLoaded', function() {
            const dayCount = @Model.DaysInMonth;
            const gridContainer = document.querySelector('.schedule-grid');
            if (gridContainer) {
                gridContainer.style.setProperty('--day-count', dayCount);
                // Also set explicit grid-template-columns for better browser support
                gridContainer.style.gridTemplateColumns = `repeat(${dayCount}, 60px)`;
            }
        });
    </script>
}
