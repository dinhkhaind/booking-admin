@model IEnumerable<RoomType>
@{ ViewData["Title"] = "Room Types"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Room Types</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Room Type
    </a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Base Capacity</th>
                <th>Status</th>
                <th class="text-end" style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var roomType in Model)
            {
                <tr>
                    <td><strong>@roomType.Name</strong></td>
                    <td>@roomType.Description</td>
                    <td class="text-center">@roomType.BaseCapacity</td>
                    <td>
                        @if (roomType.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@roomType.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@roomType.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        No room types found. <a asp-action="Create">Create one</a>
    </div>
}
