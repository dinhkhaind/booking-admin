@model RoomType
@{ ViewData["Title"] = "Edit Room Type"; }

<h2>Edit Room Type</h2>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mt-4" style="max-width: 600px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BaseCapacity" class="form-label">Base Capacity (guests)</label>
        <input asp-for="BaseCapacity" type="number" class="form-control" required />
        <span asp-validation-for="BaseCapacity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Color" class="form-label">Color</label>
        <div style="display: flex; align-items: center; gap: 10px;">
            <input asp-for="Color" type="color" class="form-control" style="width: 60px; height: 40px; cursor: pointer;" />
            <input type="text" id="colorText" class="form-control" placeholder="#2563eb" readonly />
        </div>
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Active</label>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
