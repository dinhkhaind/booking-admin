@model BookingAdmin.Web.Models.Room
@{ ViewData["Title"] = "Delete Room"; }

<h2 class="text-danger">Delete Room</h2>

<p class="mt-3">Are you sure you want to delete <strong>@Model.RoomName</strong>?</p>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
