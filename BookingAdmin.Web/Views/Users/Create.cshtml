@model BookingAdmin.Web.Models.UserCreateViewModel
@{ ViewData["Title"] = "Add User"; }

<h2>Add User</h2>

<form asp-action="Create" method="post" class="mt-4" style="max-width: 500px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Username" class="form-label">Username</label>
        <input asp-for="Username" class="form-control" required />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" type="password" class="form-control" required />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Role" class="form-label">Role</label>
        <select asp-for="Role" asp-items="@(new SelectList((IEnumerable<BookingAdmin.Web.Models.UserRole>)ViewBag.Roles))" class="form-select" required>
            <option value="">-- Select Role --</option>
        </select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
        <label asp-for="IsActive" class="form-check-label">Active</label>
    </div>

    <div class="mb-3">
        <label class="form-label">Boats Allowed to Manage</label>
        <div class="border rounded p-3" style="max-height: 250px; overflow-y: auto;">
            @if (ViewBag.Boats != null && ViewBag.Boats.Count > 0)
            {
                @foreach (var boat in ViewBag.Boats)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="boat_@boat.Id" name="selectedBoats[]" value="@boat.Id" />
                        <label class="form-check-label" for="boat_@boat.Id">@boat.Name</label>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small">No active boats available</p>
            }
        </div>
        <small class="text-muted">Leave unchecked to allow access to all boats</small>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
