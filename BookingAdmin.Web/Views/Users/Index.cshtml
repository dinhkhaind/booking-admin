@model IEnumerable<BookingAdmin.Web.Models.User>
@{ ViewData["Title"] = "Users"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Users</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add User
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Username</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@user.Username</strong></td>
                    <td><span class="badge bg-secondary">@user.Role</span></td>
                    <td>@(user.IsActive ? "<span class=\"badge bg-success\">Active</span>" : "<span class=\"badge bg-danger\">Inactive</span>")</td>
                    <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
