@model BookingAdmin.Web.Models.User
@{ ViewData["Title"] = "Delete User"; }

<h2 class="text-danger">Delete User</h2>

<p class="mt-3">Are you sure you want to delete user <strong>@Model.Username</strong>?</p>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
