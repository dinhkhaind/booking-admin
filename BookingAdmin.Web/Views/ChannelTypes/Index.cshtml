@model IEnumerable<BookingAdmin.Web.Models.ChannelType>
@{ ViewData["Title"] = "Channel Types"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Channel Types</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Channel Type
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var channelType in Model)
            {
                <tr>
                    <td><strong>@channelType.Name</strong></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@channelType.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@channelType.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No channel types found.</div>
}
