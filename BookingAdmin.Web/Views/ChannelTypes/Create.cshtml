@model BookingAdmin.Web.Models.ChannelType
@{ ViewData["Title"] = "Add Channel Type"; }

<h2>Add Channel Type</h2>

<form asp-action="Create" method="post" class="mt-4" style="max-width: 400px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g., Online, Travel Agent" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
