@model RoomScheduleViewModel

<div class="modal fade" id="blockRoomModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Block Phòng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="blockRoomForm">
                    <!-- Row 1: Boat -->
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Tàu</label>
                            <select id="BlockBoatId" name="BoatId" class="form-select" required>
                                <option value="">-- Chọn Tàu --</option>
                                @foreach (var boat in Model.Boats)
                                {
                                    <option value="@boat.Id">@boat.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Row 2: Rooms (Multi-select Checkbox) -->
                    <div class="mb-3">
                        <label class="form-label">Phòng</label>
                        <div id="BlockRoomsList" style="border: 1px solid #ddd; border-radius: 4px; padding: 10px; max-height: 250px; overflow-y: auto;">
                            <div class="text-muted">Chọn tàu trước</div>
                        </div>
                    </div>

                    <!-- Selected Rooms Display -->
                    <div class="mb-3" id="selectedRoomsDiv" style="display: none;">
                        <label class="form-label">Phòng đã chọn:</label>
                        <div id="selectedRoomsList" style="background: #f8f9fa; padding: 10px; border-radius: 4px; min-height: 30px;"></div>
                    </div>

                    <!-- Row 3: From Date & To Date -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Từ Ngày</label>
                            <input type="date" id="BlockFromDate" name="FromDate" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Đến Ngày</label>
                            <input type="date" id="BlockToDate" name="ToDate" class="form-control" required />
                        </div>
                    </div>

                    <!-- Row 3: Partner -->
                    <div class="mb-3">
                        <label class="form-label">Đối Tác Đề Nghị Block</label>
                        <input type="text" id="BlockPartner" name="Partner" class="form-control" placeholder="Nhập tên đối tác" />
                    </div>

                    <!-- Row 4: Deadline (datetime) -->
                    <div class="mb-3">
                        <label class="form-label">Hạn Block - Ngày & Giờ Chốt Cuối</label>
                        <input type="datetime-local" id="BlockDeadline" name="Deadline" class="form-control" />
                    </div>

                    <!-- Row 5: Note -->
                    <div class="mb-3">
                        <label class="form-label">Nội Dung Block / Ghi Chú</label>
                        <textarea id="BlockNote" name="Note" class="form-control" rows="3" placeholder="Nhập ghi chú..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn btn-danger" onclick="saveRoomBlock()">
                    <i class="bi bi-lock"></i> Block Phòng
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let blockModalInitData = { boatId: null, date: null };

    // Function to open block room modal
    function openBlockModal(boatId, date) {
        blockModalInitData.boatId = boatId;
        blockModalInitData.date = date;
        const modal = new bootstrap.Modal(document.getElementById('blockRoomModal'));
        modal.show();
    }

    // Initialize modal when shown
    document.getElementById('blockRoomModal').addEventListener('show.bs.modal', async function () {
        // Pre-fill boat if provided
        if (blockModalInitData.boatId) {
            document.getElementById('BlockBoatId').value = blockModalInitData.boatId;
            await loadBlockRooms();
        }

        // Pre-fill from date if provided
        if (blockModalInitData.date) {
            document.getElementById('BlockFromDate').value = blockModalInitData.date;
            document.getElementById('BlockToDate').value = blockModalInitData.date;
        }

        // Clear modal init data
        blockModalInitData = { boatId: null, date: null };
    });

    // Load rooms when boat changes
    document.getElementById('BlockBoatId').addEventListener('change', loadBlockRooms);

    async function loadBlockRooms() {
        const boatId = document.getElementById('BlockBoatId').value;
        const roomsList = document.getElementById('BlockRoomsList');

        if (!boatId) {
            roomsList.innerHTML = '<div class="text-muted">Chọn tàu trước</div>';
            return;
        }

        try {
            const response = await fetch(`/api/rooms?boatId=${boatId}`);
            const rooms = await response.json();

            roomsList.innerHTML = '';
            if (rooms.length === 0) {
                roomsList.innerHTML = '<div class="text-muted">Không có phòng</div>';
                return;
            }

            rooms.forEach(room => {
                const div = document.createElement('div');
                div.style.padding = '5px 0';
                div.innerHTML = `
                    <div class="form-check">
                        <input class="form-check-input room-checkbox" type="checkbox" id="room_${room.id}" value="${room.id}" data-room-code="${room.roomCode}" data-room-name="${room.roomName}">
                        <label class="form-check-label" for="room_${room.id}">
                            ${room.roomCode} - ${room.roomName}
                        </label>
                    </div>
                `;
                roomsList.appendChild(div);
            });

            // Add event listeners to checkboxes
            document.querySelectorAll('.room-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', updateSelectedRooms);
            });
        } catch (error) {
            console.error('Error loading rooms:', error);
            roomsList.innerHTML = '<div class="text-danger">Lỗi tải phòng</div>';
        }
    }

    function updateSelectedRooms() {
        const selectedCheckboxes = document.querySelectorAll('.room-checkbox:checked');
        const selectedDiv = document.getElementById('selectedRoomsDiv');
        const selectedList = document.getElementById('selectedRoomsList');

        if (selectedCheckboxes.length === 0) {
            selectedDiv.style.display = 'none';
            selectedList.innerHTML = '';
        } else {
            selectedDiv.style.display = 'block';
            let html = '';
            selectedCheckboxes.forEach(checkbox => {
                html += `<span class="badge bg-primary" style="margin-right: 5px;">
                    ${checkbox.getAttribute('data-room-code')} - ${checkbox.getAttribute('data-room-name')}
                </span>`;
            });
            selectedList.innerHTML = html;
        }
    }

    async function saveRoomBlock() {
        const boatId = document.getElementById('BlockBoatId').value;
        const selectedCheckboxes = document.querySelectorAll('.room-checkbox:checked');
        const roomIds = Array.from(selectedCheckboxes).map(cb => parseInt(cb.value));
        const fromDate = document.getElementById('BlockFromDate').value;
        const toDate = document.getElementById('BlockToDate').value;
        const partner = document.getElementById('BlockPartner').value || null;
        const deadline = document.getElementById('BlockDeadline').value || null;
        const note = document.getElementById('BlockNote').value || null;

        // Client-side validation
        if (!boatId || roomIds.length === 0 || !fromDate || !toDate) {
            alert('Vui lòng điền các trường bắt buộc và chọn ít nhất 1 phòng');
            return;
        }

        if (new Date(toDate) <= new Date(fromDate)) {
            alert('Ngày kết thúc phải sau ngày bắt đầu');
            return;
        }

        try {
            const response = await fetch('/lich-phong/api/room-blocks', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    boatId: parseInt(boatId),
                    roomIds: roomIds,
                    fromDate: fromDate,
                    toDate: toDate,
                    partner: partner || null,
                    deadline: deadline ? new Date(deadline).toISOString() : null,
                    note: note || null
                })
            });

            // Read response as text first to avoid JSON parsing errors
            const responseText = await response.text();
            console.log('Response text:', responseText);

            // Try to parse JSON
            let data = {};
            if (responseText) {
                try {
                    data = JSON.parse(responseText);
                } catch (parseError) {
                    console.error('JSON parse error:', parseError);
                    alert('Lỗi: Server trả về dữ liệu không hợp lệ');
                    return;
                }
            }

            // Check success status
            if (data.success === false || (response.status >= 400 && !data.success)) {
                const errorMsg = data.error || 'Lỗi tạo block phòng';
                alert('Lỗi: ' + errorMsg);
                return;
            }

            if (data.success === true) {
                alert('Block phòng thành công!');
                bootstrap.Modal.getInstance(document.getElementById('blockRoomModal')).hide();
                document.getElementById('blockRoomForm').reset();
                location.reload();
            } else {
                alert('Lỗi: Không rõ lỗi');
            }
        } catch (error) {
            console.error('Error creating block:', error);
            alert('Lỗi: ' + error.message);
        }
    }
</script>

<style>
    #blockRoomModal .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
    }

    #blockRoomModal .btn-danger:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }
</style>
