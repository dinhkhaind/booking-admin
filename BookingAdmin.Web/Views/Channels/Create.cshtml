@model BookingAdmin.Web.Models.Channel
@{ ViewData["Title"] = "Add Channel"; }

<h2>Add Channel</h2>

<form asp-action="Create" method="post" class="mt-4" style="max-width: 400px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="ChannelTypeId" class="form-label">Channel Type</label>
        <select asp-for="ChannelTypeId" asp-items="(SelectList)ViewBag.ChannelTypes" class="form-select" required>
            <option value="">-- Select Channel Type --</option>
        </select>
        <span asp-validation-for="ChannelTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g., Booking.com, Expedia" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
