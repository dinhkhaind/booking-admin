@model BookingAdmin.Web.Models.Booking
@{ ViewData["Title"] = "Delete Booking"; }

<h2 class="text-danger">Delete Booking</h2>

<p class="mt-3">Are you sure you want to delete this booking?</p>

<div class="alert alert-warning mt-3">
    <strong>Boat:</strong> @Model.Boat?.Name<br />
    <strong>Booking Code:</strong> @Model.BookingCode<br />
    <strong>Customer:</strong> @Model.CustomerName<br />
    <strong>Check-in:</strong> @Model.CheckIn.ToString("yyyy-MM-dd")<br />
    <strong>Check-out:</strong> @Model.CheckOut.ToString("yyyy-MM-dd")<br />
    <strong>Channel:</strong> @Model.Channel?.Name
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
