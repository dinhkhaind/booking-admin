@model IEnumerable<BookingAdmin.Web.Models.Booking>
@{
    ViewData["Title"] = "Booking Calendar";
    int year = ViewBag.Year;
    int month = ViewBag.Month;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Bookings T@(month) - @year</h2>
    <a asp-action="Index" class="btn btn-secondary">List view</a>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Boat</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Booking Code</th>
                <th>Customer</th>
                <th>Channel</th>
                <th>Status</th>
                <th>Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.Boat?.Name</td>
                    <td>@booking.CheckIn.ToString("yyyy-MM-dd")</td>
                    <td>@booking.CheckOut.ToString("yyyy-MM-dd")</td>
                    <td>@booking.BookingCode</td>
                    <td>@booking.CustomerName</td>
                    <td>@booking.Channel?.Name</td>
                    <td><span class="badge bg-info">@booking.Status</span></td>
                    <td>@booking.Price.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No bookings for this month.</div>
}
