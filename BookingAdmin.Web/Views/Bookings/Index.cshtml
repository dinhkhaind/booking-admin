@model IEnumerable<BookingAdmin.Web.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
    var f = (dynamic)ViewBag.Filter;
    int total = ViewBag.Total;
    int page = ViewBag.Page;
    int pageSize = ViewBag.PageSize;
    int totalPages = (int)Math.Ceiling(total / (double)pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Bookings <small class="text-muted">(@total entries)</small></h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Add Booking
        </a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto flex-grow-1">
        <input name="q" value="@f.q" placeholder="Search booking code / customer / notes" class="form-control" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" type="submit">Filter</button>
        <a class="btn btn-secondary" asp-action="Index">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Booking Code</th>
                <th>Customer</th>
                <th>Boat</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Channel</th>
                <th>Status</th>
                <th>Price</th>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("BookingStaff"))
                {
                    <th class="text-end" style="width: 120px;">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BookingCode</td>
                    <td>@b.CustomerName</td>
                    <td>@b.Boat?.Name</td>
                    <td>@b.CheckIn.ToString("yyyy-MM-dd")</td>
                    <td>@b.CheckOut.ToString("yyyy-MM-dd")</td>
                    <td>@b.Channel?.Name</td>
                    <td><span class="badge bg-info">@b.Status</span></td>
                    <td>@b.Price.ToString("C")</td>
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("BookingStaff"))
                    {
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" href="?year=@f.year&month=@f.month&roomCode=@f.roomCode&channel=@f.channel&q=@f.q&page=@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
