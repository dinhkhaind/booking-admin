@model BookingAdmin.Web.Models.BookingListViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Bookings";
    var currentUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
    var today = DateTime.Today;
}

<!-- Current User Data (for modal) -->
<div class="d-none" data-current-user="@currentUser" data-current-user-id="@currentUserId"></div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Danh sách Booking <small class="text-muted">(@Model.TotalCount kết quả)</small></h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("BookingStaff"))
    {
        <button class="btn btn-primary" onclick="openModal(@Model.ModalData.SelectedBoatId, null)">
            <i class="bi bi-plus"></i> Booking Mới
        </button>
    }
</div>

<!-- Revenue Metric -->
@if (!string.IsNullOrEmpty(Model.RevenueByCurrency))
{
    <div class="alert alert-info mb-4">
        <strong>Doanh Thu:</strong> @Html.Raw(Model.RevenueByCurrency)
    </div>
}

<!-- Filter Bar -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Tàu</label>
                <select name="boatId" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var boat in Model.Boats)
                    {
                        <option value="@boat.Id" selected="@(boat.Id == Model.BoatId)">@boat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label">Tháng</label>
                <select name="month" class="form-select">
                    <option value="">--</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.Month)">@m</option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label">Năm</label>
                <select name="year" class="form-select">
                    <option value="">--</option>
                    @for (int y = today.Year - 1; y <= today.Year + 2; y++)
                    {
                        <option value="@y" selected="@(y == Model.Year)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Loại Phòng</label>
                <select name="roomTypeId" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var rt in Model.RoomTypes)
                    {
                        <option value="@rt.Id" selected="@(rt.Id == Model.RoomTypeId)">@rt.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Trạng thái</label>
                <select name="statusId" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var s in Model.Statuses)
                    {
                        <option value="@s.Id" selected="@(s.Id == Model.StatusId)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tìm kiếm</label>
                <input name="q" value="@Model.Q" placeholder="Mã booking / Khách / Ghi chú" class="form-control" />
            </div>
            <div class="col-md-1 d-flex align-items-end gap-1">
                <button class="btn btn-primary" type="submit">Lọc</button>
                <a class="btn btn-secondary" asp-action="Index">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="table-responsive">
    <table class="table table-sm table-hover table-striped">
        <thead>
            <tr>
                <th>Code hệ thống</th>
                <th>Khách</th>
                <th>Tàu/Phòng</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Gói</th>
                <th class="text-center">Khách số</th>
                <th class="text-end">Giá</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Bookings)
            {
                var room = b.BookingRooms.FirstOrDefault()?.Room;
                <tr style="cursor:pointer" onclick="openDetailModal(@b.Id)">
                    <td><small class="font-monospace">@b.SystemCode</small></td>
                    <td>@b.CustomerName</td>
                    <td>
                        @b.Boat?.Name
                        @if (room != null) { <br /><small class="text-muted">@room.RoomCode</small> }
                    </td>
                    <td>@b.CheckIn.ToString("dd/MM/yyyy")</td>
                    <td>@b.CheckOut.ToString("dd/MM/yyyy")</td>
                    <td><small>@b.Package?.Code</small></td>
                    <td class="text-center">@(b.AdultCount + b.ChildCount + b.InfantCount)</td>
                    <td class="text-end">@b.TotalPrice.ToString("N0") @b.Currency?.Code</td>
                    <td>
                        <span class="badge" style="background-color:@b.BookingStatus?.Color">
                            @b.BookingStatus?.Name
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination">
            @for (int p = Math.Max(1, Model.Page - 3); p <= Math.Min(Model.TotalPages, Model.Page + 3); p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       href="?boatId=@Model.BoatId&month=@Model.Month&year=@Model.Year&roomTypeId=@Model.RoomTypeId&statusId=@Model.StatusId&q=@Model.Q&page=@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Booking Modal -->
@await Html.PartialAsync("_BookingModal", Model.ModalData)

<!-- Shared Detail Drawer -->
@await Html.PartialAsync("_BookingDetailDrawer")

@section Scripts {
    <script src="~/js/booking-shared.js" asp-append-version="true"></script>
}
