@model IEnumerable<BookingAdmin.Web.Models.Currency>
@{ ViewData["Title"] = "Currencies"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Currencies</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Add Currency
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var currency in Model)
            {
                <tr>
                    <td><strong>@currency.Code</strong></td>
                    <td>@currency.Name</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@currency.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@currency.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No currencies found.</div>
}
