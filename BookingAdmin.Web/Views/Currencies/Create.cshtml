@model BookingAdmin.Web.Models.Currency
@{ ViewData["Title"] = "Add Currency"; }

<h2>Add Currency</h2>

<form asp-action="Create" method="post" class="mt-4" style="max-width: 400px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Code" class="form-label">Code</label>
        <input asp-for="Code" class="form-control" placeholder="e.g., USD, VND" required />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g., US Dollar" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
