@model BookingAdmin.Web.Models.Currency
@{ ViewData["Title"] = "Delete Currency"; }

<h2 class="text-danger">Delete Currency</h2>

<p class="mt-3">Are you sure you want to delete this currency?</p>

<div class="alert alert-warning mt-3">
    <strong>Code:</strong> @Model.Code<br />
    <strong>Name:</strong> @Model.Name
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
